{
  "manifest_version": 3,
  "name": "Controlium",
  "version": "1.0.0",
  "description": "Controlium — drive your browser over the Chrome DevTools Protocol via a local MCP bridge, always bringing the working tab to the front and showing a synthetic cursor.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Controlium",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "scripting",
    "activeTab",
    "storage",
    "alarms",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "cursor-overlay.js" ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [ "<all_urls>" ],
      "resources": [ "cursor-overlay.js" ]
    }
  ],
  "icons": {
    "128": "icon-128.png"
  }
}
